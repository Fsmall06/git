# Server
PORT=3000
# Optional local/test database path. Leave empty in normal deployments to use db/database.db.
# ESP_SERVER_DB_PATH=/tmp/esp-server-smoke.sqlite

# Text-only LLM proxy: POST /api/llm/text
LLM_API_KEY=replace-with-your-server-side-key
LLM_BASE_URL=https://ai-gateway.vei.volces.com
LLM_CHAT_PATH=/v1/chat/completions
LLM_MODEL=Doubao-Seed-1.6-flash
LLM_TIMEOUT_MS=30000
# Structured LLM and command APIs use the same LLM_* gateway settings.

# Command queue: GET /api/commands/pending
# Dispatched commands without ack become visible to the device again after this timeout.
COMMAND_DISPATCH_TIMEOUT_MS=60000

# Voice turn: POST /api/voice/turn
VOICE_TURN_MOCK=1
VOICE_TURN_TIMEOUT_MS=60000
VOICE_TURN_MAX_CONCURRENT=1
VOICE_TURN_MAX_BYTES=4194304

# Volc gateway chain mode for VOICE_TURN_MOCK=0
VOLC_GATEWAY_API_KEY=replace-with-your-server-side-key
VOLC_GATEWAY_WS_BASE_URL=wss://ai-gateway.vei.volces.com
VOLC_GATEWAY_HTTP_BASE_URL=https://ai-gateway.vei.volces.com
VOLC_GATEWAY_REALTIME_PATH=/v1/realtime
VOLC_GATEWAY_CHAT_PATH=/v1/chat/completions
VOLC_GATEWAY_ASR_MODEL=bigmodel
VOLC_GATEWAY_ASR_FORMAT=pcm
VOLC_GATEWAY_ASR_CODEC=raw
VOLC_GATEWAY_ASR_SAMPLE_RATE=16000
VOLC_GATEWAY_ASR_BITS=16
VOLC_GATEWAY_ASR_CHANNELS=1
VOLC_GATEWAY_WS_AUDIO_CHUNK_BYTES=32000
VOLC_GATEWAY_CHAT_MODEL=Doubao-Seed-1.6-flash
VOLC_GATEWAY_TTS_MODEL=replace-with-tts-model
VOLC_GATEWAY_TTS_VOICE=replace-with-tts-voice
VOLC_GATEWAY_TTS_PATH=/v1/realtime
VOLC_GATEWAY_TTS_SAMPLE_RATE=16000
VOLC_GATEWAY_TTS_FORMAT=pcm_s16le_mono_16k
